+/** Bangkok is always UTC+7, no DST — safe to hard-code as a fixed IANA zone. */
+const BANGKOK_TZ = 'Asia/Bangkok';
+
+/** Format a timestamp as Thai date+time (พ.ศ., 24h clock) in Bangkok local
+ *  time, regardless of the server's own clock. Vercel's Node runtime clock
+ *  is UTC, so any `.toLocaleString('th-TH')` call without an explicit
+ *  timeZone silently renders 7 hours behind real Thai time — every such
+ *  call site must go through this helper instead. */
+export function formatThaiDateTime(value: string | number | Date): string {
+  const d = value instanceof Date ? value : new Date(value);
+  return d.toLocaleString('th-TH', { timeZone: BANGKOK_TZ });
