+++ b/src/app/api/vehicles/list/route.ts
@@ -0,0 +1,36 @@
+import { NextRequest, NextResponse } from 'next/server';
+import { getSession } from '@/lib/auth';
+import { listVehicles } from '@/lib/db';
+import { seesAllDealers } from '@/lib/scope';
+
+export const dynamic = 'force-dynamic';
+
+/**
+ * Full vehicle list (Supabase `vehicles` table, capped at 5000), used to
+ * power the report form's serial dropdown - the form preloads this once and
+ * filters client-side as the user types, so suggestions appear instantly
+ * with no per-keystroke round trip.
+ *
+ * This route was missing entirely (report-form.tsx called it but it 404'd),
+ * which is why the dropdown never appeared no matter what was typed - the
+ * underlying `listVehicles()` data-layer function already existed in
+ * src/lib/db.ts, it just had no route wired up to it.
+ */
+export async function GET(req: NextRequest) {
+  const session = await getSession();
+  if (!session) {
+    return NextResponse.json({ ok: false, error: 'unauthorized' }, { status: 401 });
+  }
+  const dealerId = seesAllDealers(session.role) ? null : session.dealerId;
+
+  try {
+    const results = await listVehicles(dealerId);
+    return NextResponse.json({ ok: true, results });
+  } catch (err: any) {
+    console.error('vehicle list error', err);
+    return NextResponse.json(
+      { ok: false, error: err?.message ?? 'โหลดรายการเลขรถไม่สำเร็จ' },
+      { status: 500 }
+    );
+  }
+}
