+  // Manual "ค้นหา" button - hits the live search endpoint (Supabase +
+  // Tractor IN sheet) instead of only filtering the preloaded list. Useful
+  // when a unit was just added and hasn't synced into the preloaded list yet,
+  // or for partial matches beyond the preloaded list's 5000-row cap.
+  async function searchVehiclesManually() {
+    const term = serial.trim();
+    if (!term) return;
+    setManualSearching(true);
+    setSearchOpen(true);
+    try {
+      const res = await fetch(`/api/vehicles/search?q=${encodeURIComponent(term)}`);
+      const json = await res.json();
+      if (json.ok) {
+        setSearchResults((prev) => {
+          const merged = new Map<string, VehicleSearchResult>();
+          for (const r of prev) merged.set(r.serial.toUpperCase(), r);
+          for (const r of json.results as VehicleSearchResult[]) merged.set(r.serial.toUpperCase(), r);
+          return Array.from(merged.values()).slice(0, 30);
+        });
+      }
+    } catch {
+      /* ignore - dropdown just keeps whatever local matches it already had */
+    } finally {
+      setManualSearching(false);
+    }
+  }
