# Environment configuration reference for MASP / mqr-webapp-new.
# Copy to .env.local for local development; set the same names in
# Vercel's Project Settings -> Environment Variables for deployed
# environments. Never commit a real .env.local/.env file.

# ---------------------------------------------------------------------
# Required - the app will not start/behave correctly without these.
# ---------------------------------------------------------------------

# Supabase project (src/lib/supabase.ts). Read lazily at call time, but
# every DB/Storage-backed route needs both.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Session signing (src/lib/auth.ts, src/middleware.ts). A long, random
# secret - session cookies are unverifiable without it.
SESSION_SECRET=

# Google Drive OAuth2 (src/lib/googleDrive.ts) - the archive storage
# backend (GoogleDriveStorageProvider) and the legacy QIR upload
# pipeline (api/upload/*) both depend on these three.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
# The Drive folder ID every archived/uploaded file is organized under.
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Resend (src/lib/email.ts) - required for the record-notification email
# feature to actually send.
RESEND_API_KEY=

# ---------------------------------------------------------------------
# Optional - has a real, safe default; only set to override it.
# ---------------------------------------------------------------------

# Sender address for outbound Resend email. Defaults to
# 'onboarding@resend.dev' (Resend's own sandbox sender) if unset -
# fine for testing, not a real production "from" address.
RESEND_FROM_EMAIL=

# Recipient for the record-notification email. If unset, email.ts skips
# sending rather than throwing - notifications are a nice-to-have, not
# a hard dependency for the app to function.
MQR_NOTIFY_EMAIL=

# Public base URL of the deployed app, used server-to-server (e.g.
# src/features/maintenance/utils/fetchMaintenance.ts's internal fetch).
# On Vercel, falls back to Vercel's own auto-provided VERCEL_URL, then
# to http://localhost:3000 - only needs to be set explicitly for a
# non-Vercel deployment target.
NEXT_PUBLIC_APP_URL=

# "Tractor IN" Google Sheet (src/lib/tractorSheet.ts). Both have real,
# working defaults pointing at the production sheet - only override to
# point at a different sheet (e.g. a test copy).
TRACTOR_SHEET_ID=
TRACTOR_SHEET_GID=

# Storage Platform provider selection (src/shared/attachments/StorageProviderFactory.ts).
# Unset = today's real, unchanged default everywhere: primary=SUPABASE,
# archive=GOOGLE_DRIVE. Do not set STORAGE_PROVIDER=CLOUDFLARE_R2 in any
# real environment without first completing the production prerequisites
# in docs/release/STORAGE_PLATFORM_RELEASE.md (Cloudflare R2 CORS is not
# yet configured as of this baseline). ARCHIVE_PROVIDER=CLOUDFLARE_R2 is
# rejected outright by StorageProviderFactory - do not set it.
STORAGE_PROVIDER=
ARCHIVE_PROVIDER=

# Storage Hygiene retention window, in hours, before an orphan finding is
# treated as abandoned rather than in-flight (src/shared/attachments/orphanConfig.ts).
# Defaults to 24 if unset or invalid - never throws.
ORPHAN_RETENTION_HOURS=

# ---------------------------------------------------------------------
# Required only if STORAGE_PROVIDER or ARCHIVE_PROVIDER=CLOUDFLARE_R2
# ---------------------------------------------------------------------
# Not used anywhere in production today (CloudflareR2Provider is
# implemented but not selected by default - see
# docs/engineering/STORAGE_PLATFORM_DECISION.md). getR2Config() throws
# immediately, naming the specific missing var, if these are read while
# unset and CLOUDFLARE_R2 is actually selected.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# No R2_PUBLIC_URL - CloudflareR2Provider deliberately never returns a
# permanent/public object URL (R2 Production Readiness hardening). If an
# old .env.local still has this set, it is simply unread, not an error.

# ---------------------------------------------------------------------
# Development only / not user-configured
# ---------------------------------------------------------------------
# NODE_ENV - set automatically by Next.js/Node tooling (development,
# production, test). Do not set this manually in .env.local/.env.

# VERCEL_URL - set automatically by Vercel at build/runtime. Do not set
# this manually; it exists only as a fallback source for
# NEXT_PUBLIC_APP_URL above when deployed on Vercel.

# scripts/get-google-refresh-token.mjs (npm run drive:auth) is a one-off,
# interactive local setup helper for producing GOOGLE_OAUTH_REFRESH_TOKEN
# above - it is not run in production and needs no environment variables
# of its own beyond GOOGLE_OAUTH_CLIENT_ID/GOOGLE_OAUTH_CLIENT_SECRET.
